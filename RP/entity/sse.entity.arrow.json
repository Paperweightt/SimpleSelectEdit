{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "sse:arrow",
            "materials": {
                "default": "outline_base", // Must have due to custom material keeping the base on front.
                "outline": "outline" // For outline.
            },
            "textures": {
                "red": "textures/entity/red",
                "green": "textures/entity/green",
                "blue": "textures/entity/blue",
                "outline": "textures/ui/White" // Outline texture
            },
            "geometry": {
                "default": "geometry.sse.arrow", // Base geometry
                "outline": "geometry.sse.arrow_outline" // Outline geometry - Same as base but inflated.
            },
            "render_controllers": [
                "controller.render.sse.entity.arrow",
                "controller.render.arx.entity.outline" // For outline.
            ],
            "animations": {
                "scale_by_distance": "animation.scale_head",
                "rotate_head": "animation.rotate_head",
                "controller.head": "controller.animation.rotate_head",
                "controller.scale": "controller.animation.scale_by_distance"
            },
            "scripts": {
                "animate": ["controller.head", "controller.scale"]
            }
        }
    }
}
