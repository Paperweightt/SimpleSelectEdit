{
    "format_version": "1.10.0",
    "render_controllers": {
        "controller.render.sse.entity.arrow": {
            "filter_lighting": true,
            "geometry": "Array.geo[query.property('sse:mode')]",
            "textures": ["Array.axis[query.property('sse:axis')]"],
            "arrays": {
                "textures": {
                    "Array.axis": ["Texture.red", "Texture.green", "Texture.blue"]
                },
                "geometries": {
                    "Array.geo": ["Geometry.arrow", "Geometry.resize", "Geometry.stretch"]
                }
            },
            "ignore_lighting": true,
            "materials": [
                {
                    "*": "Material.default"
                }
            ]
        }
    }
}
