{
    "format_version": "1.8.0",
    "animations": {
        "animation.rotate_head": {
            "loop": true,
            "bones": {
                "head": {
                    "rotation": [
                        "-query.property('sse:rotate_head_y')",
                        "query.property('sse:rotate_head_x')",
                        "0"
                    ]
                }
            }
        },
        "animation.scale_head": {
            "loop": true,
            "bones": {
                "head": {
                    "scale": "(query.distance_from_camera/11)+1"
                }
            }
        }
    }
}
